#!/bin/sh
# spark — shell wrapper that execs the native binary directly.
#
# The platform-specific binary is installed by npm as an optionalDependency
# into node_modules/@dpeluche/spark-cli-<os>-<arch>/spark.

set -e

# Resolve real location of this script (npm installs it as a symlink).
SCRIPT="$0"
while [ -L "$SCRIPT" ]; do
  LINK=$(readlink "$SCRIPT")
  case "$LINK" in
    /*) SCRIPT="$LINK" ;;
    *) SCRIPT="$(dirname "$SCRIPT")/$LINK" ;;
  esac
done
DIR="$(cd "$(dirname "$SCRIPT")" && pwd)"
# DIR is .../node_modules/@dpeluche/spark/bin

OS=$(uname -s)
ARCH=$(uname -m)
case "$OS" in
  Darwin) OS=darwin ;;
  Linux) OS=linux ;;
  *) echo "spark: unsupported OS: $OS" >&2; exit 1 ;;
esac
case "$ARCH" in
  x86_64|amd64) ARCH=x64 ;;
  arm64|aarch64) ARCH=arm64 ;;
  *) echo "spark: unsupported arch: $ARCH" >&2; exit 1 ;;
esac

PKG="@dpeluche/spark-cli-$OS-$ARCH"
BIN=""

# Env override takes priority (custom builds / debugging)
if [ -n "${SPARK_BINARY:-}" ] && [ -x "$SPARK_BINARY" ]; then
  BIN="$SPARK_BINARY"
fi

# Candidate locations npm may use for the optional dependency:
#  - sibling: hoisted to parent node_modules (npm local install, npm >=7)
#  - nested:  inside our own node_modules (npm install -g, pnpm isolated)
#  - parent:  deduplicated one level up (workspaces)
if [ -z "$BIN" ]; then
  for candidate in \
    "$DIR/../../spark-cli-$OS-$ARCH/spark" \
    "$DIR/../node_modules/$PKG/spark" \
    "$DIR/../../../$PKG/spark" \
    "$DIR/../../node_modules/$PKG/spark"; do
    if [ -x "$candidate" ]; then
      BIN="$candidate"
      break
    fi
  done
fi

if [ -z "$BIN" ]; then
  echo "spark: platform binary not found" >&2
  echo "" >&2
  echo "Expected package: $PKG" >&2
  echo "Searched near:    $DIR" >&2
  echo "" >&2
  echo "Alternatives:" >&2
  echo "  cargo install --git https://github.com/dPeluChe/spark" >&2
  echo "  curl -fsSL https://raw.githubusercontent.com/dPeluChe/spark/main/scripts/install.sh | sh" >&2
  exit 1
fi

exec "$BIN" "$@"
